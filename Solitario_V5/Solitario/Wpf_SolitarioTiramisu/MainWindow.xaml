<Window x:Class="Wpf_SolitarioTiramisu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_SolitarioTiramisu"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" ResizeMode="NoResize">
    <Grid OpacityMask="White">
        <Grid.Background>
            <ImageBrush ImageSource="/Screenshot 2024-05-28 121542.png"/>
        </Grid.Background>
        <Label x:Name="lbl" Content="Inserire Il Nome Del Giocatore" HorizontalAlignment="Center" Height="72" Margin="0,27,0,0" VerticalAlignment="Top" Width="496" Foreground="#FFF0BC51" FontSize="48" FontFamily="Edwardian Script ITC"/>
        <TextBox x:Name="txtNome" HorizontalAlignment="Center" Height="37" Margin="0,128,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="224" TextAlignment="Center" FontSize="20" Background="{x:Null}" BorderBrush="#FFF0BC51" Foreground="#FFF0BC51"/>
        <Button x:Name="btnStart" Content="Inizia" HorizontalAlignment="Center" Height="59" Margin="0,217,0,0" VerticalAlignment="Top" Width="224" Background="{x:Null}" BorderBrush="#FFF0BC51" BorderThickness="1,1,1,1" Foreground="#FFEFBC51" FontSize="24" FontFamily="Times New Roman" Click="btnStart_Click"/>
    </Grid>
</Window>
