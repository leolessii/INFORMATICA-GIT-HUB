<Window x:Class="Wpf_SolitarioTiramisu.PaginaFinale"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_SolitarioTiramisu"
        mc:Ignorable="d"
        Title="PaginaFinale" Height="450" Width="800" ResizeMode="NoResize">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Screenshot 2024-05-28 121542.png"/>
        </Grid.Background>
        <Label x:Name="lbl" Content="Congratulazioni !" Margin="259,27,259,304" Foreground="#FFF0BC51" FontSize="48" FontFamily="Edwardian Script ITC" HorizontalContentAlignment="Center"/>
        <TextBlock x:Name="txtNome" HorizontalAlignment="Center" Margin="0,135,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="72" Width="282" TextAlignment="Center" Foreground="#FFF0BC51" FontFamily="Edwardian Script ITC" FontSize="36" FontWeight="Bold"/>
        <Button x:Name="btnStart" Content="Rigioca" HorizontalAlignment="Center" Margin="0,244,0,131" Width="224" Background="{x:Null}" BorderBrush="#FFF0BC51" BorderThickness="1,1,1,1" Foreground="#FFEFBC51" FontSize="24" FontFamily="Times New Roman" Click="btnStart_Click"/>
    </Grid>
</Window>
